---
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import FormattedDate from "../components/FormattedDate.astro";
import Header from "../components/Header.astro";
import { SITE_DESCRIPTION } from "../consts";

type Props = CollectionEntry<"blog">["data"];

const { title, description, author, date, updatedDate, heroImage, tags } = Astro.props;
---

<html lang="en">
    <head>
        <BaseHead
    title={title}
    description={description || SITE_DESCRIPTION}
    image={heroImage}
    type="article"
    date={date}
    updatedDate={updatedDate}
    author={author}
    tags={tags}
/>
        <style>
            main {
                width: calc(100% - 2em);
                max-width: 100%;
                margin: 0;
            }
            .hero-image {
                width: 100%;
                max-width: 1020px;
                margin: 0 auto;
            }
            .hero-image img {
                display: block;
                margin: 0 auto;
                border-radius: 12px;
                box-shadow: var(--box-shadow);
                width: 100%;
                height: auto;
                aspect-ratio: 21 / 9;
                object-fit: cover;
            }
            .prose {
                width: 720px;
                max-width: calc(100% - 2em);
                margin: auto;
                padding: 0 1em 1em;
                color: rgb(var(--gray-dark));
            }
            .title {
                padding: 1.5em 1em 0.5em;
                text-align: center;
                line-height: 1;
            }
            .title h1 {
                margin: 0;
            }
            .meta {
                text-align: center;
                padding: 0.5em 1em 1em;
            }
            .date {
                color: rgb(var(--gray));
            }
            .last-updated-on {
                font-style: italic;
            }
        </style>
    </head>

    <body>
        <Header />
        <main>
            <article>
                <div class="title">
                    <h1>{title}</h1>
                </div>
                <div class="hero-image">
                    {
                        heroImage && (
                            <Image
                                width={1020}
                                height={437}
                                src={heroImage}
                                alt=""
                            />
                        )
                    }
                </div>
                <div class="meta">
                    <div class="date">
                        <FormattedDate date={date} />
                        {
                            updatedDate && (
                                <div class="last-updated-on">
                                    Last updated on{" "}
                                    <FormattedDate date={updatedDate} />
                                </div>
                            )
                        }
                    </div>
                    <hr />
                </div>
                <div class="prose">
                    <slot />
                </div>
            </article>
        </main>
        <Footer />
    </body>
</html>
