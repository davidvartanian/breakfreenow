---
---

<section class="hero">
	<div class="hero-content">
		<h1>Break Free from Your Golden Handcuffs</h1>
		<p class="hero-subtitle">Strategic guidance for experienced professionals transitioning to entrepreneurial freedom</p>
		<div class="hero-actions">
			<a href="/blog/" class="btn">Read the Blog</a>
			<a href="/contact-me/" class="btn btn-secondary">Contact Me</a>
		</div>
	</div>
</section>

<style>
	.hero {
		background: linear-gradient(135deg, var(--bg-cream) 0%, var(--bg-warm) 100%);
		padding: 4em 1em;
		text-align: center;
		border-bottom: 1px solid rgba(var(--gray-light), 80%);
	}
	.hero-content {
		max-width: 720px;
		margin: 0 auto;
	}
	.hero h1 {
		margin: 0 0 0.5em 0;
		font-size: 2.8em;
		line-height: 1.15;
		color: rgb(var(--black));
	}
	.hero-subtitle {
		font-size: 1.25em;
		color: var(--text-secondary);
		margin: 0 0 1.5em 0;
		line-height: 1.5;
	}
	.hero-actions {
		display: flex;
		gap: 1em;
		justify-content: center;
		flex-wrap: wrap;
	}
	@media (max-width: 720px) {
		.hero {
			padding: 2.5em 1em;
		}
		.hero h1 {
			font-size: 2em;
		}
		.hero-subtitle {
			font-size: 1.1em;
		}
	}
</style>
