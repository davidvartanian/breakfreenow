---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<h2><a href="/" class="site-title"><img src="/favicon.svg" alt="" class="site-logo" />{SITE_TITLE}</a></h2>
		<input type="checkbox" id="nav-toggle" class="nav-toggle" />
		<label for="nav-toggle" class="nav-toggle-label" aria-label="Toggle navigation">
			<span></span>
			<span></span>
			<span></span>
		</label>
		<div class="nav-menu">
			<div class="internal-links">
				<HeaderLink href="/">Home</HeaderLink>
				<HeaderLink href="/blog">Blog</HeaderLink>
				<div class="dropdown">
					<HeaderLink href="/about-me">About</HeaderLink>
					<div class="dropdown-menu">
						<a href="/my-philosophy">My Philosophy</a>
					</div>
				</div>
				<HeaderLink href="/services">Services</HeaderLink>
				<HeaderLink href="/contact-me">Contact</HeaderLink>
			</div>
			<div class="social-links">
				<a href="https://www.linkedin.com/in/davidvartanian/" target="_blank">
					<span class="sr-only">Connect on LinkedIn</span>
					<svg viewBox="0 0 24 24" aria-hidden="true" width="32" height="32"
						><path
							fill="currentColor"
							d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
						></path></svg
					>
				</a>
				<a href="https://www.facebook.com/profile.php?id=61577342136778" target="_blank">
					<span class="sr-only">Follow on Facebook</span>
					<svg viewBox="0 0 24 24" aria-hidden="true" width="32" height="32"
						><path
							fill="currentColor"
							d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"
						></path></svg
					>
				</a>
			</div>
		</div>
	</nav>
</header>
<style>
	header {
		margin: 0;
		padding: 0 1em;
		background: white;
		box-shadow: 0 2px 8px rgba(var(--black), 5%);
		position: sticky;
		top: 0;
		z-index: 100;
	}
	h2 {
		margin: 0;
		font-size: 1.1em;
		font-weight: 700;
	}
	h2 a,
	h2 a.active {
		text-decoration: none;
		color: rgb(var(--black));
	}
	.site-title {
		display: inline-flex;
		align-items: center;
		gap: 0.4em;
	}
	.site-logo {
		height: 1.3em;
		width: auto;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		position: relative;
	}
	.nav-toggle {
		display: none;
	}
	.nav-toggle-label {
		display: none;
		flex-direction: column;
		gap: 5px;
		cursor: pointer;
		padding: 0.5em;
	}
	.nav-toggle-label span {
		display: block;
		width: 24px;
		height: 2px;
		background: rgb(var(--black));
		transition: all 0.3s ease;
	}
	.nav-menu {
		display: flex;
		align-items: center;
		gap: 2rem;
	}
	.internal-links {
		display: flex;
		align-items: center;
		gap: 0;
	}
	.internal-links > :global(a),
	.internal-links > .dropdown > :global(a) {
		padding: 1em 0.75em;
		color: rgb(var(--black));
		border-bottom: 3px solid transparent;
		text-decoration: none;
		font-size: 0.95em;
		font-weight: 500;
	}
	.internal-links > :global(a.active),
	.internal-links > .dropdown > :global(a.active) {
		border-bottom-color: var(--accent);
	}
	.dropdown {
		position: relative;
	}
	.dropdown-menu {
		display: none;
		position: absolute;
		top: 100%;
		left: 0;
		background: white;
		box-shadow: 0 4px 12px rgba(var(--black), 10%);
		border-radius: 8px;
		padding: 0.5em 0;
		min-width: 160px;
		z-index: 101;
	}
	.dropdown-menu a {
		display: block;
		padding: 0.6em 1em;
		color: rgb(var(--black));
		text-decoration: none;
		font-size: 0.9em;
		white-space: nowrap;
	}
	.dropdown-menu a:hover {
		background: var(--bg-warm);
		color: var(--accent);
	}
	.dropdown:hover .dropdown-menu {
		display: block;
	}
	.social-links,
	.social-links a {
		display: flex;
		align-items: center;
	}
	.social-links a {
		padding: 0.5em;
		color: rgb(var(--gray));
	}
	.social-links a:hover {
		color: var(--accent);
	}

	@media (max-width: 720px) {
		header {
			padding: 0.75em 1em;
		}
		nav {
			flex-wrap: wrap;
		}
		.nav-toggle-label {
			display: flex;
		}
		.nav-menu {
			display: none;
			width: 100%;
			flex-direction: column;
			align-items: stretch;
			padding: 1em 0;
			gap: 0;
		}
		.nav-toggle:checked ~ .nav-menu {
			display: flex;
		}
		.internal-links {
			flex-direction: column;
			width: 100%;
		}
		.internal-links > :global(a),
		.internal-links > .dropdown > :global(a) {
			padding: 0.75em 0;
			border-bottom: 1px solid rgb(var(--gray-light));
			font-size: 1.1em;
		}
		.dropdown {
			width: 100%;
		}
		.dropdown-menu {
			display: block;
			position: static;
			box-shadow: none;
			padding: 0 0 0 1em;
			background: transparent;
		}
		.dropdown-menu a {
			padding: 0.5em 0;
			border-bottom: none;
			font-size: 1em;
			color: var(--text-secondary);
		}
		.social-links {
			justify-content: center;
			padding-top: 1em;
			border-top: 1px solid rgb(var(--gray-light));
			margin-top: 0.5em;
		}
		.nav-toggle:checked ~ .nav-toggle-label span:nth-child(1) {
			transform: rotate(45deg) translate(5px, 5px);
		}
		.nav-toggle:checked ~ .nav-toggle-label span:nth-child(2) {
			opacity: 0;
		}
		.nav-toggle:checked ~ .nav-toggle-label span:nth-child(3) {
			transform: rotate(-45deg) translate(5px, -5px);
		}
	}
</style>
