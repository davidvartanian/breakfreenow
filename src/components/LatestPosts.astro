---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import FormattedDate from './FormattedDate.astro';

const posts = (await getCollection('blog'))
	.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
	.slice(0, 6);
---

<section class="latest-posts">
	<div class="section-header">
		<h2>Latest Posts</h2>
		<a href="/blog/" class="view-all">View All</a>
	</div>
	<div class="posts-grid">
		{
			posts.map((post) => (
				<article class="post-card">
					<a href={`/blog/${post.id}/`} class="post-link">
						{post.data.heroImage && (
							<div class="post-image">
								<Image width={400} src={post.data.heroImage} alt="" />
							</div>
						)}
						<div class="post-content">
							<h3 class="post-title">{post.data.title}</h3>
							<p class="post-date">
								<FormattedDate date={post.data.date} />
							</p>
						</div>
					</a>
				</article>
			))
		}
	</div>
</section>

<style>
	.latest-posts {
		padding: 3em 1em;
		max-width: 960px;
		margin: 0 auto;
	}
	.section-header {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		margin-bottom: 1.5em;
		padding-bottom: 0.5em;
		border-bottom: 2px solid var(--accent);
	}
	.section-header h2 {
		margin: 0;
		font-size: 1.75em;
	}
	.view-all {
		font-size: 0.95em;
		font-weight: 600;
	}
	.posts-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1.5em;
	}
	.post-card {
		background: white;
		border-radius: 12px;
		overflow: hidden;
		box-shadow: 0 2px 8px rgba(var(--black), 5%);
		transition: box-shadow 0.2s ease, transform 0.2s ease;
	}
	.post-card:hover {
		box-shadow: 0 8px 24px rgba(var(--black), 10%);
		transform: translateY(-2px);
	}
	.post-link {
		display: block;
		text-decoration: none;
		color: inherit;
	}
	.post-link:hover {
		text-decoration: none;
	}
	.post-image {
		width: 100%;
		height: 180px;
		overflow: hidden;
	}
	.post-image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
		border-radius: 0;
	}
	.post-content {
		padding: 1em;
	}
	.post-title {
		margin: 0 0 0.4em 0;
		font-size: 1.05em;
		line-height: 1.3;
		color: rgb(var(--black));
	}
	.post-date {
		margin: 0;
		font-size: 0.85em;
		color: var(--text-secondary);
	}

	@media (max-width: 720px) {
		.latest-posts {
			padding: 2em 1em;
		}
		.posts-grid {
			grid-template-columns: 1fr;
			gap: 1em;
		}
		.post-image {
			height: 200px;
		}
		.section-header h2 {
			font-size: 1.5em;
		}
	}
</style>
